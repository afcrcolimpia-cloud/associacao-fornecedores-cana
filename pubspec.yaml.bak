name: associacaofornecedorescana
description: Sistema de Gestão Agrícola AFCRC
publish_to: 'none'

version: 1.0.0+1

environment:
  sdk: '>=3.0.0 <4.0.0'

dependencies:
  flutter:
    sdk: flutter
  cupertino_icons: ^1.0.2
  firebase_core: ^2.15.1
  firebase_auth: ^4.9.0 
  cloud_firestore: ^4.9.1
  firebase_storage: ^11.2.6
  provider: ^6.0.5
  shared_preferences: ^2.2.1
  intl: ^0.18.1
  file_picker: ^5.5.0
  url_launcher: ^6.1.14
  share_plus: ^7.1.0
  path: ^1.8.3
  mask_text_input_formatter: ^2.5.0
  image_picker: ^1.0.4
  cached_network_image: ^3.2.3
  shimmer: ^3.0.0
  flutter_native_splash: ^2.3.2
  google_fonts: ^5.1.0
  flutter_launcher_icons: ^0.13.1
  local_auth: ^2.1.7
  google_sign_in: ^6.1.5
  gradient_ui: ^1.0.1
  logger: ^2.0.2

dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_lints: ^2.0.3

flutter:
  uses-material-design: true
  
  assets:
    - assets/imagens/
    - assets/icons/
    - assets/logo/

flutter_native_splash:
  color: "#1B5E20"
  image: assets/imagens/splash.png
  android: true
  ios: true

flutter_icons:
  android: true
  ios: true
  image_path: "assets/icons/app_icon.png"
  adaptive_icon_background: "#1B5E20"
  adaptive_icon_foreground: "assets/icons/app_icon_foreground.png"